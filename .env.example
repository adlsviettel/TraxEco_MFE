# TraxEco Frontend Environment Variables
# Copy this file to .env.development or .env.production and modify properties as needed

# URL to connect to the backend API.
# Dev mode: leave as /api to let Vite proxy handle it
# Production: set to the absolute URL of your backend (e.g., http://172.17.186.26:8100/api)
VITE_API_BASE_URL=/api

# Deployment base path (leave as / if deploying to root domain, or /subfolder/ if not)
VITE_BASE_PATH=/

# URL of the photo web server
VITE_IMAGE_BASE_URL=http://192.168.1.248/FbwarehouseImg
