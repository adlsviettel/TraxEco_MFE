{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@traxeco/shared": ["../shared/src"],
      "@traxeco/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src"]
}
